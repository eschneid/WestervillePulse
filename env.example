# WestervillePulse — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git!

# Notion
NOTION_TOKEN=ntn_your_token_here
NOTION_PARENT_PAGE_ID=your_parent_page_id_here

# Google Places API
GOOGLE_API_KEY=AIza_your_google_api_key_here

# Eventbrite (optional)
# EVENTBRITE_API_KEY=your_key_here

# Claude API — AI-generated news summaries + digest intro
ANTHROPIC_API_KEY=sk-ant-...

# Email digest (Gmail SMTP)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Create one named "WestervillePulse" and paste the 16-char code below
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
DIGEST_TO=you@gmail.com,friend@example.com
